<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Cron job para actualizar tasa BCV diariamente -->
    <record id="ir_cron_update_bcv_rate" model="ir.cron">
        <field name="name">Venezuela: Actualizar tasa BCV</field>
        <field name="model_id" ref="base.model_res_currency"/>
        <field name="state">code</field>
        <field name="code">model.l10n_ve_update_rate_yadio()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="doall">False</field>
    </record>
</odoo>
