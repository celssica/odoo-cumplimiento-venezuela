<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_ve" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ve</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='default_taxes']" position="after">
                <block title="Venezuela" id="venezuela_settings">
                    <setting string="Unidad Tributaria">
                        <field name="l10n_ve_ut_amount"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
