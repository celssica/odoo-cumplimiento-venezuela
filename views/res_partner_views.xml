<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_partner_form_inherit_ve" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.ve</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="l10n_ve_rif" placeholder="J-12345678-9"/>
                <field name="l10n_ve_responsibility_type"/>
            </xpath>
        </field>
    </record>
</odoo>
